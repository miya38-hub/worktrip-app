<div class="container py-4">

  <!-- タイトル -->
  <h1 class="mb-4 fw-bold">データ管理</h1>

  <!-- KPI -->
  <div class="row mb-4 g-3">
    <div class="col-md-6">
      <div class="card shadow-sm text-center p-3">
        <h6 class="text-muted mb-1">総いいね数</h6>
        <h2 class="fw-bold text-danger"><%= @favorite_data.sum %></h2>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm text-center p-3">
        <h6 class="text-muted mb-1">総投稿数</h6>
        <h2 class="fw-bold text-primary"><%= @spot_data.sum %></h2>
      </div>
    </div>
  </div>

  <div class="row g-4">

    <!-- グラフ -->
    <div class="col-lg-8">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title mb-3">いいね・投稿数の推移</h5>
          <div style="height: 350px;">
            <canvas id="analyticsChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- ランキング -->
    <div class="col-lg-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title mb-3">人気スポット</h5>

          <% if @popular_spots.present? %>
            <ul class="list-group list-group-flush">
              <% @popular_spots.each_with_index do |spot, i| %>
                <li class="list-group-item d-flex justify-content-between align-items-center">

                  <div>
                    <span class="fw-bold me-2 text-primary">#<%= i + 1 %></span>
                    <%= spot.name %>
                  </div>

                  <span class="badge bg-primary rounded-pill px-3">
                    ❤️ <%= spot.try(:favorites_count) || spot.favorites.count %>
                  </span>

                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-muted">データがまだありません</p>
          <% end %>

        </div>
      </div>
    </div>

  </div>
</div>

<script>
document.addEventListener("turbo:load", () => {
  const ctx = document.getElementById('analyticsChart');
  if (!ctx) return;

  if (window.analyticsChart instanceof Chart) {
    window.analyticsChart.destroy();
  }

  window.analyticsChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: <%= raw @labels.to_json %>,
      datasets: [
        {
          label: 'いいね数',
          data: <%= raw @favorite_data.to_json %>,
          borderColor: '#dc3545',
          backgroundColor: 'rgba(220,53,69,0.1)',
          tension: 0.3,
          pointRadius: 4
        },
        {
          label: '投稿数',
          data: <%= raw @spot_data.to_json %>,
          borderColor: '#0d6efd',
          backgroundColor: 'rgba(13,110,253,0.1)',
          tension: 0.3,
          pointRadius: 4
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'top'
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            precision: 0
          }
        }
      }
    }
  });
});
</script>