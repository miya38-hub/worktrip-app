<div class="container py-4">

  <h1 class="mb-4 fw-bold">分析ダッシュボード</h1>

  <div class="row g-4">

    <!-- グラフ -->
    <div class="col-lg-8">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title mb-3">いいね・投稿数の推移</h5>
          <div style="height: 350px;">
            <canvas id="analyticsChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- ランキング -->
    <div class="col-lg-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title mb-3">人気スポット</h5>

          <ul class="list-group list-group-flush">
            <% @popular_spots.each_with_index do |spot, i| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= i + 1 %>. <%= spot.name %></span>
                <span class="badge bg-primary rounded-pill">
                  <%= spot.favorites.count %>
                </span>
              </li>
            <% end %>
          </ul>

        </div>
      </div>
    </div>

  </div>
</div>

<script>
document.addEventListener("turbo:load", () => {
  const ctx = document.getElementById('analyticsChart');
  if (!ctx) return;

  if (window.analyticsChart instanceof Chart) {
    window.analyticsChart.destroy();
  }

  window.analyticsChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: <%= raw @labels.to_json %>,
      datasets: [
        {
          label: 'いいね数',
          data: <%= raw @favorite_data.to_json %>,
          borderColor: '#dc3545',
          backgroundColor: 'rgba(220,53,69,0.1)',
          tension: 0.3,
          pointRadius: 4
        },
        {
          label: '投稿数',
          data: <%= raw @spot_data.to_json %>,
          borderColor: '#0d6efd',
          backgroundColor: 'rgba(13,110,253,0.1)',
          tension: 0.3,
          pointRadius: 4
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'top'
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            precision: 0
          }
        }
      }
    }
  });
});
</script>