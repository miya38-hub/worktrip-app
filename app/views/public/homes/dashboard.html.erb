<div class="container py-5">

  <!-- タイトル -->
  <div class="text-center mb-5">
    <h2 class="fw-bold">今日の作業場所を見つけよう</h2>
    <p class="text-muted">
      WiFi・電源・レビューから最適なスポットを
    </p>
  </div>

  <!-- ヘッダー -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">おすすめスポット</h4>
    <%= link_to "一覧を見る", spots_path, class: "text-decoration-none" %>
  </div>

  <!-- カード一覧 -->
  <div class="row">
    <% @spots.each do |spot| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0">

          <div class="card-body d-flex flex-column">

            <!-- タイトル -->
            <h5 class="fw-bold mb-2">
              <%= link_to spot.name, spot_path(spot),
                class: "text-decoration-none text-dark" %>
            </h5>

            <!-- 住所 -->
            <p class="text-muted small mb-2">
              <i class="fa-solid fa-location-dot me-1"></i>
              <%= spot.address %>
            </p>

            <!-- 説明（追加） -->
            <p class="text-secondary small mb-3 flex-grow-1">
              <%= truncate(spot.description.presence || "説明はまだありません", length: 50) %>
            </p>

            <!-- バッジ -->
            <div class="mb-3 d-flex flex-wrap gap-2">
              <% if spot.wifi %>
                <span class="badge bg-success">WiFi</span>
              <% end %>

              <% if spot.power_supply %>
                <span class="badge bg-primary">電源</span>
              <% end %>

              <span class="badge bg-secondary">
                💬 <%= spot.comments.count %>
              </span>
            </div>

            <!-- 下部 -->
            <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">

              <small class="text-muted">
                レビュー <%= spot.reviews.count %>件
              </small>

              <%= link_to "詳細",
                spot_path(spot),
                class: "btn btn-outline-primary btn-sm" %>

            </div>

          </div>

        </div>
      </div>
    <% end %>
  </div>

</div>