<div class="container text-center py-5">

  <!-- ヒーロー -->
  <h1 class="fw-bold mb-3 display-5">
    出張先でも、最高の作業環境を。
  </h1>

  <p class="text-muted mb-4 fs-5">
    WiFi・電源・作業しやすさがわかるレビューアプリ
  </p>

  <div class="d-flex justify-content-center gap-3 mb-4">
    <%= link_to "🔍 スポットを見る", spots_path, class: "btn btn-primary btn-lg px-4 shadow" %>

    <%= button_to "👀 ゲストで試す",
      guest_login_session_path,
      method: :post,
      form: { data: { turbo: false } },
      class: "btn btn-outline-primary btn-lg px-4" %>
  </div>

</div>

<hr class="my-5">

<!-- サービス説明 -->
<div class="container text-center">
  <div class="row g-4">

    <div class="col-md-4">
      <div class="p-4 shadow-sm rounded bg-white h-100">
        <div class="mb-3 fs-2 text-primary">📶</div>
        <h5 class="fw-bold">WiFi・電源</h5>
        <p class="text-muted small">設備情報をすぐ確認</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow-sm rounded bg-white h-100">
        <div class="mb-3 fs-2 text-warning">⭐</div>
        <h5 class="fw-bold">レビュー</h5>
        <p class="text-muted small">作業しやすさがわかる</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow-sm rounded bg-white h-100">
        <div class="mb-3 fs-2 text-danger">📍</div>
        <h5 class="fw-bold">出張対応</h5>
        <p class="text-muted small">どこでも作業環境を探せる</p>
      </div>
    </div>

  </div>
</div>