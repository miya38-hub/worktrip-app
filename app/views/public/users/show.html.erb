<div class="container mt-4 mb-5">

  <!-- プロフィール -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start justify-content-between gap-4">

        <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start gap-4">
          <div class="text-center">
            <% if @user.profile_image.attached? %>
              <%= image_tag @user.profile_image.variant(resize_to_fill: [120, 120]),
                class: "rounded-circle border shadow-sm" %>
            <% else %>
              <%= image_tag "no_image.jpg",
                class: "rounded-circle border shadow-sm",
                width: 120,
                height: 120 %>
            <% end %>
          </div>

          <div class="text-center text-md-start">
            <h3 class="fw-bold mb-1"><%= @user.name %></h3>
            <p class="text-muted mb-2"><%= @user.email_address %></p>
            <p class="mb-0 text-secondary">
              <%= @user.introduction.presence || "自己紹介はまだありません" %>
            </p>
          </div>
        </div>

        <% if @user == current_user %>
          <div>
            <%= link_to "プロフィール編集", edit_user_path(@user), class: "btn btn-outline-primary px-4" %>
          </div>
        <% end %>

      </div>
    </div>
  </div>

  <!-- 統計 -->
  <div class="row text-center mb-4 g-3">
    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body py-4">
          <h4 class="fw-bold mb-1"><%= @spots.count %></h4>
          <p class="text-muted mb-0">投稿</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body py-4">
          <h4 class="fw-bold mb-1"><%= @favorites.count %></h4>
          <p class="text-muted mb-0">お気に入り</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body py-4">
          <h4 class="fw-bold mb-1"><%= @reviews.count %></h4>
          <p class="text-muted mb-0">レビュー</p>
        </div>
      </div>
    </div>
  </div>

  <!-- タブ -->
  <ul class="nav nav-tabs mb-4">
    <li class="nav-item">
      <a class="nav-link active" data-bs-toggle="tab" href="#spots">スポット</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#favorites">お気に入り</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#reviews">レビュー</a>
    </li>
  </ul>

  <div class="tab-content">

    <!-- スポット -->
    <div class="tab-pane fade show active" id="spots">
      <% if @spots.any? %>
        <div class="row">
          <% @spots.each do |spot| %>
            <div class="col-md-6 col-lg-4 mb-4">
              <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4 d-flex flex-column">

                  <!-- タイトル -->
                  <h5 class="fw-bold mb-2">
                    <%= link_to spot.name, spot_path(spot), class: "text-decoration-none text-dark" %>
                  </h5>

                  <!-- 住所 -->
                  <p class="text-muted small mb-3">
                    <i class="fa-solid fa-location-dot me-1"></i>
                    <%= spot.address %>
                  </p>

                  <!-- 説明 -->
                  <p class="text-secondary small mb-3 flex-grow-1">
                    <%= truncate(spot.description.presence || "説明はまだありません", length: 60) %>
                  </p>

                  <!-- バッジ -->
                  <div class="mb-3">
                    <% if spot.wifi %>
                      <span class="badge bg-success me-2 px-3 py-2">WiFi</span>
                    <% end %>

                    <% if spot.power_supply %>
                      <span class="badge bg-primary me-2 px-3 py-2">電源</span>
                    <% end %>

                    <span class="badge bg-secondary px-3 py-2">
                      💬 <%= spot.comments.count %>
                    </span>
                  </div>

                  <!-- 下部 -->
                  <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                    <small class="text-muted">
                      レビュー <%= spot.reviews.count %>件
                    </small>

                    <%= link_to "詳細を見る", spot_path(spot), class: "btn btn-outline-primary btn-sm" %>
                  </div>

                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="card border-0 bg-light">
          <div class="card-body text-center text-muted py-5">
            まだ投稿がありません
          </div>
        </div>
      <% end %>
    </div>

    <!-- お気に入り -->
    <div class="tab-pane fade" id="favorites">
      <div class="card border-0 bg-light">
        <div class="card-body text-center text-muted py-5">
          お気に入りはまだありません
        </div>
      </div>
    </div>

    <!-- レビュー -->
    <div class="tab-pane fade" id="reviews">
      <div class="card border-0 bg-light">
        <div class="card-body text-center text-muted py-5">
          レビューはまだありません
        </div>
      </div>
    </div>

  </div>

</div>