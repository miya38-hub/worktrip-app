<% range_label = {
  "User" => "ユーザー",
  "Spot" => "投稿"
} %>

<% match_label = {
  "perfect_match" => "完全一致",
  "forward_match" => "前方一致",
  "backward_match" => "後方一致",
  "partial_match" => "部分一致"
} %>

<div class="container mt-4">
  <h2 class="mb-4">検索結果</h2>

  <p class="text-muted">
    <%= range_label[@range] %>検索 /
    キーワード: <%= @word %> /
    検索方法: <%= match_label[@match] %>
  </p>

  <% if @range == "User" %>
    <% if @users.present? %>
      <% @users.each do |user| %>
        <div class="card mb-3 shadow-sm">
          <div class="card-body">
            <h5 class="card-title">
              <%= link_to user.name, user_path(user), class: "text-decoration-none" %>
            </h5>
            <p class="text-muted mb-0"><%= user.email_address %></p>
          </div>
        </div>
      <% end %>
    <% else %>
      <p>該当するユーザーがいません。</p>
    <% end %>

  <% elsif @range == "Spot" %>
    <% if @spots.present? %>
      <% @spots.each do |spot| %>
        <div class="card mb-3 shadow-sm">
          <div class="card-body">
            <h5 class="card-title">
              <%= link_to spot.name, spot_path(spot), class: "text-decoration-none" %>
            </h5>
            <p class="text-muted mb-1">住所: <%= spot.address %></p>
            <p class="text-muted mb-0">投稿者: <%= spot.user.name %></p>
          </div>
        </div>
      <% end %>
    <% else %>
      <p>該当する投稿がありません。</p>
    <% end %>
  <% end %>
</div>