<div class="container mt-4">

  <!-- スポット情報 -->
  <div class="card shadow-sm p-4 mb-4">

    <!-- タイトル -->
    <h2 class="mb-2"><%= @spot.name %></h2>
    <p class="text-muted"><%= @spot.address %></p>

    <!-- 平均評価 -->
    <div class="mb-2">
      <span class="text-warning fs-5">
        <% avg = @spot.reviews.average(:rating)&.round(1) %>

        <% if avg.present? %>
          <% avg.floor.times do %>
            <i class="fa-solid fa-star"></i>
          <% end %>
          <% (5 - avg.floor).times do %>
            <i class="fa-regular fa-star"></i>
          <% end %>
          <span class="ms-2 text-dark"><%= avg %></span>
        <% else %>
          <span class="text-muted">未評価</span>
        <% end %>
      </span>

      <small class="text-muted">
        （<%= @spot.reviews.count %>件）
      </small>
    </div>

    <hr>

    <!-- 設備 -->
    <div class="mb-3">
      <% if @spot.wifi %>
        <span class="badge bg-success me-2">WiFi</span>
      <% end %>

      <% if @spot.power_supply %>
        <span class="badge bg-primary">電源</span>
      <% end %>
    </div>

    <!-- 説明 -->
    <div class="mb-3">
      <h5>説明</h5>
      <p><%= @spot.description.presence || "説明はまだありません" %></p>
    </div>

    <!-- 投稿者 -->
    <div class="d-flex align-items-center mb-3">
      <% if @spot.user.profile_image.attached? %>
        <%= image_tag @spot.user.profile_image, class: "rounded-circle me-2", width: 40, height: 40 %>
      <% else %>
        <%= image_tag "no_image.jpg", class: "rounded-circle me-2", width: 40, height: 40 %>
      <% end %>
      <strong><%= @spot.user.name %></strong>
    </div>

    <!-- ボタン -->
    <% if @spot.user == current_user %>
      <div>
        <%= link_to "編集", edit_spot_path(@spot), class: "btn btn-outline-primary me-2" %>
        <%= button_to "削除",
          @spot,
          method: :delete,
          data: { turbo_confirm: "本当に削除しますか？" },
          class: "btn btn-outline-danger" %>
      </div>
    <% end %>

  </div>

  <!-- レビュー -->
  <div>

    <h4 class="mb-3">レビュー</h4>

    <% if @reviews.any? %>

      <% @reviews.each do |review| %>
        <div class="card mb-3 shadow-sm border-0">

          <div class="card-body">

            <!-- 投稿者 -->
            <div class="d-flex align-items-center mb-2">
              <% if review.user.profile_image.attached? %>
                <%= image_tag review.user.profile_image, class: "rounded-circle me-2", width: 40, height: 40 %>
              <% else %>
                <%= image_tag "no_image.jpg", class: "rounded-circle me-2", width: 40, height: 40 %>
              <% end %>
              <strong><%= review.user.name %></strong>
            </div>

            <!-- 総合評価 -->
            <div class="text-warning mb-2">
              <% review.rating.to_i.times do %>
                <i class="fa-solid fa-star"></i>
              <% end %>
              <% (5 - review.rating.to_i).times do %>
                <i class="fa-regular fa-star"></i>
              <% end %>
            </div>

            <!-- 項目別評価 -->
            <div class="small mb-2">

              <div>
                WiFi:
                <% review.wifi_rating.to_i.times do %>
                  <i class="fa-solid fa-star text-warning"></i>
                <% end %>
                <% (5 - review.wifi_rating.to_i).times do %>
                  <i class="fa-regular fa-star text-warning"></i>
                <% end %>
              </div>

              <div>
                電源:
                <% review.power_rating.to_i.times do %>
                  <i class="fa-solid fa-star text-warning"></i>
                <% end %>
                <% (5 - review.power_rating.to_i).times do %>
                  <i class="fa-regular fa-star text-warning"></i>
                <% end %>
              </div>

              <div>
                静かさ:
                <% review.quietness_rating.to_i.times do %>
                  <i class="fa-solid fa-star text-warning"></i>
                <% end %>
                <% (5 - review.quietness_rating.to_i).times do %>
                  <i class="fa-regular fa-star text-warning"></i>
                <% end %>
              </div>

              <div>
                作業:
                <% review.workability_rating.to_i.times do %>
                  <i class="fa-solid fa-star text-warning"></i>
                <% end %>
                <% (5 - review.workability_rating.to_i).times do %>
                  <i class="fa-regular fa-star text-warning"></i>
                <% end %>
              </div>

            </div>

            <!-- コメント -->
            <p class="mb-1">
              <%= review.comment.presence || "コメントなし" %>
            </p>

            <!-- 日付 -->
            <small class="text-muted">
              <%= review.created_at.strftime("%Y/%m/%d") %>
            </small>

          </div>

        </div>
      <% end %>

    <% else %>
      <p class="text-muted">まだレビューはありません</p>
    <% end %>

  </div>

</div>