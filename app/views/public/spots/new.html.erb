<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <div class="card shadow">
        <div class="card-body">

          <h2 class="mb-4 text-center">新規スポット投稿</h2>

          <%= form_with model: @spot, data: { turbo: false } do |f| %>

            <!-- エラー表示 -->
            <% if @spot.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @spot.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- 名前 -->
            <div class="mb-3">
              <%= f.label :name, "スポット名", class: "form-label" %>
              <%= f.text_field :name, class: "form-control", placeholder: "例：スターバックス渋谷店" %>
            </div>

            <!-- カテゴリ -->
            <div class="mb-3">
              <%= f.label :category, "カテゴリ", class: "form-label" %>
              <%= f.select :category,
                Spot.categories.keys.map { |k| [k.humanize, k] },
                { prompt: "カテゴリを選択してください" },
                class: "form-select" %>
            </div>

            <!-- 住所 -->
            <div class="mb-3">
              <%= f.label :address, "住所", class: "form-label" %>
              <%= f.text_field :address, class: "form-control", placeholder: "東京都〇〇区..." %>
            </div>

            <!-- WiFi & 電源 -->
            <div class="mb-3">
              <div class="form-check">
                <%= f.check_box :wifi, class: "form-check-input" %>
                <%= f.label :wifi, "WiFiあり", class: "form-check-label" %>
              </div>

              <div class="form-check">
                <%= f.check_box :power_supply, class: "form-check-input" %>
                <%= f.label :power_supply, "電源あり", class: "form-check-label" %>
              </div>
            </div>

            <!-- 詳細 -->
            <div class="mb-3">
              <%= f.label :description, "詳細", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "作業のしやすさや雰囲気など..." %>
            </div>

            <!-- レビュー -->
            <hr class="my-4">
            <h4 class="mb-3">初回レビュー（任意）</h4>

            <%= hidden_field_tag "review[rating]", nil, id: "rating-input" %>
            <%= hidden_field_tag "review[wifi_rating]", nil, id: "wifi-input" %>
            <%= hidden_field_tag "review[power_rating]", nil, id: "power-input" %>
            <%= hidden_field_tag "review[quietness_rating]", nil, id: "quiet-input" %>
            <%= hidden_field_tag "review[workability_rating]", nil, id: "work-input" %>

            <div class="mb-3">
              <label>総合評価</label>
              <div id="star-rating"></div>
            </div>

            <div class="mb-3">
              <label>WiFi</label>
              <div id="star-wifi"></div>
            </div>

            <div class="mb-3">
              <label>電源</label>
              <div id="star-power"></div>
            </div>

            <div class="mb-3">
              <label>静かさ</label>
              <div id="star-quiet"></div>
            </div>

            <div class="mb-3">
              <label>作業しやすさ</label>
              <div id="star-work"></div>
            </div>

            <!-- コメント -->
            <div class="mb-3">
              <label class="form-label">コメント</label>
              <%= text_area_tag "review[comment]", nil,
                  class: "form-control",
                  rows: 3,
                  placeholder: "実際に使ってみた感想..." %>
            </div>

            <!-- ボタン -->
            <div class="text-center">
              <%= f.submit "投稿する", class: "btn btn-primary px-5" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>