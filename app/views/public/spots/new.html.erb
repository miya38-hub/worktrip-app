<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <div class="card shadow">
        <div class="card-body">

          <h2 class="mb-4 text-center">新規スポット投稿</h2>

          <%= form_with model: @spot, data: { turbo: false } do |f| %>

            <!-- エラー表示 -->
            <% if @spot.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @spot.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- 名前 -->
            <div class="mb-3">
              <%= f.label :name, "スポット名", class: "form-label" %>
              <%= f.text_field :name, class: "form-control", placeholder: "例：スターバックス渋谷店" %>
            </div>

            <!-- カテゴリ -->
            <div class="mb-3">
              <%= f.label :category, "カテゴリ", class: "form-label" %>
              <%= f.select :category, Spot.categories.keys.map { |k| [k.humanize, k] }, {}, class: "form-select" %>
            </div>

            <!-- 住所 -->
            <div class="mb-3">
              <%= f.label :address, "住所", class: "form-label" %>
              <%= f.text_field :address, class: "form-control", placeholder: "東京都〇〇区..." %>
            </div>

            <!-- WiFi & 電源 -->
            <div class="mb-3">
              <div class="form-check">
                <%= f.check_box :wifi, class: "form-check-input" %>
                <%= f.label :wifi, "WiFiあり", class: "form-check-label" %>
              </div>

              <div class="form-check">
                <%= f.check_box :power_supply, class: "form-check-input" %>
                <%= f.label :power_supply, "電源あり", class: "form-check-label" %>
              </div>
            </div>

            <!-- 詳細 -->
            <div class="mb-3">
              <%= f.label :description, "詳細", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "作業のしやすさや雰囲気など..." %>
            </div>

            <!-- ボタン -->
            <div class="text-center">
              <%= f.submit "投稿する", class: "btn btn-primary px-5" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>