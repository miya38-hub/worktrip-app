<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow-sm">
        <div class="card-body">

          <h2 class="mb-4 text-center">スポット編集</h2>

          <%= form_with model: @spot, data: { turbo: false } do |f| %>

            <!-- エラー -->
            <% if @spot.errors.any? %>
              <div class="alert alert-danger">
                <ul>
                  <% @spot.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- 名前 -->
            <div class="mb-3">
              <%= f.label :name, "スポット名", class: "form-label" %>
              <%= f.text_field :name, class: "form-control" %>
            </div>

            <!-- カテゴリ -->
            <div class="mb-3">
              <%= f.label :category, "カテゴリ", class: "form-label" %>
              <%= f.select :category,
                Spot.categories.keys.map { |k| [I18n.t("enums.spot.category.#{k}"), k] },
                {},
                class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= f.label :postal_code, "郵便番号", class: "form-label" %>
              <%= f.text_field :postal_code,
                  class: "form-control",
                  id: "postal_code",
                  placeholder: "例：1000001" %>
            </div>

            <!-- 住所 -->
            <div class="mb-3">
              <%= f.label :address, "住所", class: "form-label" %>
              <%= f.text_field :address,
                  class: "form-control",
                  id: "address" %>
            </div>

            <!-- 設備 -->
            <div class="mb-3">
              <label class="form-label">設備</label><br>

              <%= f.check_box :wifi %>
              <%= f.label :wifi, "WiFiあり", class: "me-3" %>

              <%= f.check_box :power_supply %>
              <%= f.label :power_supply, "電源あり" %>
            </div>

            <!-- 説明 -->
            <div class="mb-3">
              <%= f.label :description, "説明", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 4 %>
            </div>

            <!-- ボタン -->
            <div class="text-center">
              <%= f.submit "更新する", class: "btn btn-primary px-4" %>
            </div>

          <% end %>

         <div class="text-center mt-3">
            <%= button_to "削除",
              spot_path(@spot),
              method: :delete,
              data: { turbo_confirm: "本当に削除しますか？" },
              class: "btn btn-outline-danger px-4" %>
          </div>
          
        </div>
      </div>

    </div>
  </div>
</div>