<div class="container mt-4 mb-5">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1">スポット一覧</h2>
      <p class="text-muted mb-0">作業しやすいスポットを探しましょう</p>
    </div>

    <%= link_to "＋ 投稿", new_spot_path, class: "btn btn-primary px-4" %>
  </div>

  <% if @spots.any? %>
    <div class="row">
      <% @spots.each do |spot| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4 d-flex flex-column">

              <!-- タイトル -->
              <h5 class="card-title fw-bold mb-2">
                <%= link_to spot.name, spot_path(spot), class: "text-decoration-none text-dark" %>
              </h5>

              <!-- 住所 -->
              <p class="text-muted small mb-3">
                <i class="fa-solid fa-location-dot me-1"></i>
                <%= spot.address %>
              </p>

              <!-- 説明 -->
              <p class="text-secondary small mb-3 flex-grow-1">
                <%= truncate(spot.description.presence || "説明はまだありません", length: 60) %>
              </p>

              <!-- バッジ -->
              <div class="mb-3">
                <% if spot.wifi %>
                  <span class="badge bg-success me-2 px-3 py-2">WiFi</span>
                <% end %>

                <% if spot.power_supply %>
                  <span class="badge bg-primary me-2 px-3 py-2">電源</span>
                <% end %>

                <span class="badge bg-secondary px-3 py-2">
                  💬 <%= spot.comments.count %>
                </span>
              </div>

              <!-- 下部情報 -->
              <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                <small class="text-muted">
                  レビュー <%= spot.reviews.count %>件
                </small>

                <%= link_to "詳細を見る", spot_path(spot), class: "btn btn-outline-primary btn-sm" %>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 bg-light">
      <div class="card-body text-center text-muted py-5">
        まだスポットが投稿されていません
      </div>
    </div>
  <% end %>

</div>