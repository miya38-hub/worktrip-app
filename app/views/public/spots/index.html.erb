<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>スポット一覧</h2>
    <%= link_to "＋ 投稿", new_spot_path, class: "btn btn-primary" %>
  </div>

  <div class="row">
    <% @spots.each do |spot| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0">

          <div class="card-body">

            <!-- タイトル -->
            <h5 class="card-title">
              <%= link_to spot.name, spot_path(spot), class: "text-decoration-none text-dark" %>
            </h5>

            <!-- 住所 -->
            <p class="text-muted small mb-2">
              <%= spot.address %>
            </p>

            <!-- 簡易バッジ -->
            <div>
              <% if spot.wifi %>
                <span class="badge bg-success">WiFi</span>
              <% end %>

              <% if spot.power_supply %>
                <span class="badge bg-primary">電源</span>
              <% end %>
            </div>

          </div>

        </div>
      </div>
    <% end %>
  </div>

</div>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @spots %>
</div>