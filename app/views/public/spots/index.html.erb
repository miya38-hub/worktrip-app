<% if authenticated? %>
  <div class="bg-light border-bottom py-3">
    <div class="container">

      <%= form_with url: spots_path, method: :get, local: true do |f| %>
        <div class="card shadow-sm border-0 p-3">

          <!-- 🔥 フィルター（上段） -->
          <div class="row g-3 align-items-end mb-3">

            <div class="col-md-2">
              <label class="form-label small text-muted">検索対象</label>
              <%= f.select :range,
                options_for_select([["投稿", "Spot"], ["ユーザー", "User"]], params[:range]),
                {},
                class: "form-select" %>
            </div>

            <div class="col-md-3">
              <label class="form-label small text-muted">カテゴリ</label>
              <%= f.select :category,
                options_for_select(
                  [["すべて", ""]] + Spot.categories.keys.map { |c| [I18n.t("enums.spot.category.#{c}"), c] },
                  params[:category]
                ),
                {},
                class: "form-select" %>
            </div>

            <div class="col-md-3">
              <label class="form-label small text-muted">並び替え</label>
              <%= f.select :sort,
                options_for_select([
                  ["新着順", ""],
                  ["いいね順", "favorites"],
                  ["コメント順", "comments"]
                ], params[:sort]),
                {},
                class: "form-select" %>
            </div>

            <!-- チェックボックス -->
            <div class="col-md-4">
              <label class="form-label small text-muted">設備</label>
              <div class="d-flex gap-4">
                <div class="form-check">
                  <%= f.check_box :wifi, { checked: params[:wifi] == "1", class: "form-check-input" }, "1", "0" %>
                  <%= f.label :wifi, "WiFiあり", class: "form-check-label" %>
                </div>

                <div class="form-check">
                  <%= f.check_box :power_supply, { checked: params[:power_supply] == "1", class: "form-check-input" }, "1", "0" %>
                  <%= f.label :power_supply, "電源あり", class: "form-check-label" %>
                </div>
              </div>
            </div>

            <!-- ボタン -->
            <div class="col-md-3 d-flex gap-2">
              <%= f.submit "🔍 検索",
                class: "btn btn-primary w-100 fw-bold shadow-sm" %>

              <%= link_to "リセット",
                spots_path,
                class: "btn btn-outline-secondary w-100" %>
            </div>

          </div>

          <!-- 🔥 キーワード入力（下段） -->
          <div class="row g-3">

            <div class="col-md-6">
              <label class="form-label small text-muted">キーワード</label>
              <%= f.text_field :word,
                value: params[:word],
                placeholder: "カフェ・静か・作業など",
                class: "form-control" %>
            </div>

            <div class="col-md-6">
              <label class="form-label small text-muted">地域</label>
              <%= f.text_field :region,
                value: params[:region],
                placeholder: "渋谷・新宿など",
                class: "form-control" %>
            </div>

          </div>

        </div>

      <% end %>

    </div>
  </div>
<% end %>

<div class="container mt-4 mb-5">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1">スポット一覧</h2>
      <p class="text-muted mb-0">作業しやすいスポットを探しましょう</p>
    </div>

    <%= link_to "＋ 投稿", new_spot_path, class: "btn btn-primary px-4" %>
  </div>

  <% if @spots.any? %>
    <div class="row">
      <% @spots.each do |spot| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4 d-flex flex-column">

              <!-- タイトル -->
              <h5 class="card-title fw-bold mb-2">
                <%= link_to spot.name, spot_path(spot), class: "text-decoration-none text-dark" %>
              </h5>

              <!-- 住所 -->
              <p class="text-muted small mb-3">
                <i class="fa-solid fa-location-dot me-1"></i>
                <%= spot.address %>
              </p>

              <!-- 説明 -->
              <p class="text-secondary small mb-3 flex-grow-1">
                <%= truncate(spot.description.presence || "説明はまだありません", length: 60) %>
              </p>

              <!-- バッジ -->
              <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
                <% if spot.wifi %>
                  <span class="badge bg-success me-2 px-3 py-2">WiFi</span>
                <% end %>

                <% if spot.power_supply %>
                  <span class="badge bg-primary me-2 px-3 py-2">電源</span>
                <% end %>

                <span class="badge bg-secondary px-3 py-2">
                  💬 <%= spot.comments_count || 0 %>
                </span>

                <!-- ❤️ いいね -->
                <% if spot.favorites.count > 0 %>
                  <span class="badge bg-danger-subtle text-danger border px-3 py-2">
                    ❤️ <%= spot.favorites_count || 0 %>
                  </span>
                <% else %>
                  <span class="badge bg-light text-muted border px-3 py-2">
                    🤍 0
                  </span>
                <% end %>   
              </div>

              <!-- 下部情報 -->
            <div class="d-flex justify-content-between align-items-center pt-2 border-top">

              <!-- 左：レビュー -->
              <small class="text-muted">
                レビュー <%= spot.reviews.count %>件
              </small>

              <div class="d-flex align-items-center gap-2">

                <!-- 詳細 -->
                <%= link_to "詳細",
                  spot_path(spot),
                  class: "btn btn-outline-primary btn-sm" %>

              </div>

            </div>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 bg-light">
      <div class="card-body text-center text-muted py-5">
        まだスポットが投稿されていません
      </div>
    </div>
  <% end %>

</div>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @spots %>
</div>

