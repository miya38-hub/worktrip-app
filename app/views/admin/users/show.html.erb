<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">ユーザー詳細</h2>
    <%= link_to "一覧へ戻る", admin_users_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">

      <div class="mb-3">
        <strong>ID:</strong>
        <%= @user.id %>
      </div>

      <div class="mb-3">
        <strong>名前:</strong>
        <%= @user.name %>
      </div>

      <div class="mb-3">
        <strong>メールアドレス:</strong>
        <%= @user.email_address %>
      </div>

      <div class="mb-3">
        <strong>自己紹介:</strong>
        <%= @user.introduction.presence || "未入力" %>
      </div>

      <div class="mb-4">
        <strong>ステータス:</strong>
        <% if @user.is_active %>
          <span class="badge bg-success">有効</span>
        <% else %>
          <span class="badge bg-secondary">退会済み</span>
        <% end %>
      </div>

      <% if @user.is_active %>
        <%= button_to "退会処理を行う",
          withdraw_admin_user_path(@user),
          method: :patch,
          data: { turbo_confirm: "本当に退会処理を行いますか？" },
          class: "btn btn-danger" %>
      <% end %>

    </div>
  </div>
</div>