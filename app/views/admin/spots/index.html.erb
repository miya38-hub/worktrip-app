<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">スポット一覧</h2>
    <%= link_to "ユーザー一覧へ",
        admin_users_path,
        class: "btn btn-outline-secondary" %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body">

      <table class="table align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>スポット名</th>
            <th>投稿者</th>
            <th>住所</th>
            <th>レビュー数</th>
            <th>コメント数</th>
            <th></th>
          </tr>
        </thead>

        <tbody>
          <% @spots.each do |spot| %>
            <tr>
              <td><%= spot.id %></td>
              <td><%= spot.name %></td>
              <td><%= spot.user.name %></td>
              <td><%= spot.address %></td>
              <td><%= spot.reviews.count %></td>
              <td><%= spot.comments.count %></td>

              <td>
                <%= link_to "詳細",
                  admin_spot_path(spot),
                  class: "btn btn-outline-primary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- 🔥 ここに追加 -->
      <div class="d-flex justify-content-center mt-4">
        <%= paginate @spots %>
      </div>

    </div>
  </div>

</div>