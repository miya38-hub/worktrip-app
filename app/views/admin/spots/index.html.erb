<div class="container mt-4">

  <!-- タイトル -->
  <h2 class="mb-4 fw-bold">スポット一覧</h2>

  <!-- テーブル -->
  <table class="table table-striped table-hover align-middle shadow-sm">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>スポット名</th>
        <th>投稿者</th>
        <th>住所</th>
        <th>レビュー</th>
        <th>コメント</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% @spots.each do |spot| %>
        <tr>

          <!-- ID -->
          <td class="text-muted small">
            <%= spot.id %>
          </td>

          <!-- スポット名 -->
          <td class="fw-bold">
            <%= link_to spot.name,
              admin_spot_path(spot),
              class: "text-decoration-none text-dark" %>
          </td>

          <!-- 投稿者 -->
          <td>
            <%= spot.user.name %>
          </td>

          <!-- 住所 -->
          <td class="text-muted small">
            <%= truncate(spot.address, length: 40) %>
          </td>

          <!-- レビュー数 -->
          <td class="fw-bold text-primary">
            <%= spot.reviews.count %>
          </td>

          <!-- コメント数 -->
          <td class="fw-bold text-secondary">
            <%= spot.comments.count %>
          </td>

          <!-- 詳細 -->
          <td>
            <%= link_to "詳細",
              admin_spot_path(spot),
              class: "btn btn-outline-primary btn-sm px-3" %>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>

  <!-- ページネーション -->
  <div class="d-flex justify-content-center mt-3">
    <%= paginate @spots %>
  </div>

</div>