<div class="container mt-4">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <h2 class="fw-bold mb-4">スポット編集</h2>

      <%= form_with model: @spot, data: { turbo: false } do |f| %>
        <% if @spot.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @spot.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :name, "スポット名", class: "form-label" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :category, "カテゴリ", class: "form-label" %>
          <%= f.select :category,
            Spot.categories.keys.map { |k| [I18n.t("enums.spot.category.#{k}"), k] },
            {},
            class: "form-select" %>
        </div>

        <div class="mb-3">
          <%= f.label :postal_code, "郵便番号", class: "form-label" %>
          <%= f.text_field :postal_code,
            class: "form-control",
            id: "postal_code",
            placeholder: "例：1000001（ハイフンなし）" %>
        </div>

        <div class="mb-3">
          <%= f.label :address, "住所", class: "form-label" %>
          <%= f.text_field :address, class: "form-control", id: "address" %>  
        </div>

        <div class="mb-3">
          <%= f.label :description, "説明", class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-control" %>
        </div>

        <div class="form-check mb-2">
          <%= f.check_box :wifi, class: "form-check-input" %>
          <%= f.label :wifi, "WiFiあり", class: "form-check-label" %>
        </div>

        <div class="form-check mb-4">
          <%= f.check_box :power_supply, class: "form-check-input" %>
          <%= f.label :power_supply, "電源あり", class: "form-check-label" %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "更新する", class: "btn btn-primary" %>
          <%= link_to "戻る", admin_spot_path(@spot), class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>