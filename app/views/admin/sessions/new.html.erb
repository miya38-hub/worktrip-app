<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-5">

      <div class="card shadow border-0">
        <div class="card-body p-4">
          <h3 class="text-center mb-4 fw-bold">管理者ログイン</h3>

          <% if flash[:alert] %>
            <div class="alert alert-danger">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= form_with url: admin_login_path, method: :post, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :email_address, "メールアドレス", class: "form-label" %>
              <%= f.email_field :email_address, class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= f.label :password, "パスワード", class: "form-label" %>
              <%= f.password_field :password, class: "form-control" %>
            </div>

            <%= f.submit "ログイン", class: "btn btn-primary w-100" %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>