<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
  
  <!-- ロゴ -->
  <%= link_to "WorkTrip",
  (current_user ? dashboard_path : root_path),
  class: "navbar-brand fw-bold" %>

  <!-- ハンバーガー（スマホ対応） -->
  <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
    <span class="navbar-toggler-icon"></span>
  </button>

  <div class="collapse navbar-collapse" id="navbarNav">
    
    <!-- 左寄せ -->
    <ul class="navbar-nav me-auto">
      <% if current_user %>
        <li class="nav-item">
          <%= link_to "スポット一覧", spots_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "新規投稿", new_spot_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "マイページ", user_path(current_user), class: "nav-link" %>
        </li>
      <% else %>
        <li class="nav-item">
          <%= link_to "About", about_path, class: "nav-link" %>
        </li>
      <% end %>
    </ul>

    <!-- 右寄せ -->
    <ul class="navbar-nav">
      <% if current_user %>
        <li class="nav-item">
          <span class="navbar-text me-3">
            <%= current_user.name %> さん
          </span>
        </li>
        <li class="nav-item">
          <%= button_to "ログアウト",
              session_path,
              method: :delete,
              class: "btn btn-outline-light btn-sm" %>
        </li>
      <% else %>
        <li class="nav-item">
          <%= link_to "新規登録", new_user_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "ログイン", new_session_path, class: "btn btn-outline-light btn-sm ms-2" %>
        </li>
      <% end %>
    </ul>

  </div>
</nav>

<% if authenticated? %>
  <div class="bg-light border-bottom py-3">
    <div class="container">
      <%= form_with url: search_path, method: :get, local: true, class: "d-flex justify-content-center gap-2 flex-wrap" do |f| %>
        
        <%= f.text_field :word,
          placeholder: "キーワードを入力",
          class: "form-control w-25" %>

        <%= f.select :range,
          options_for_select([["ユーザー", "User"], ["投稿", "Spot"]], params[:range]),
          {},
          class: "form-select w-auto" %>

        <%= f.select :match,
          options_for_select([
            ["完全一致", "perfect_match"],
            ["前方一致", "forward_match"],
            ["後方一致", "backward_match"],
            ["部分一致", "partial_match"]
          ], params[:match]),
          {},
          class: "form-select w-auto" %>

        <%= f.submit "検索", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
<% end %>